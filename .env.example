# Environment Variables Example
# Copy this file to .env.local for local development
# Configure these in Railway web service → Variables for production

# ============================================================================
# CORE INFRASTRUCTURE
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL via Drizzle ORM)
# ----------------------------------------------------------------------------
# PostgreSQL connection string — Railway Postgres (use DATABASE_PUBLIC_URL from
# the Postgres service for local dev, or the internal URL inside Railway).
DATABASE_URL=postgresql://postgres:[password]@[host].proxy.rlwy.net:[port]/railway

# ----------------------------------------------------------------------------
# Object Storage (S3-compatible)
# ----------------------------------------------------------------------------
# Local dev: MinIO via docker compose up -d minio
BUCKET_ENDPOINT=http://localhost:9000
BUCKET_FORCE_PATH_STYLE=true
BUCKET_REGION=us-east-1
BUCKET_MEDIA_NAME=media
BUCKET_MEDIA_ACCESS_KEY_ID=minioadmin
BUCKET_MEDIA_SECRET_ACCESS_KEY=minioadmin
# Production: Railway Bucket (Tigris) — bucket name: media-qws-mwr1uwvl2hbr93m, region: sin
# Set these in Railway web service → Variables (credentials in Railway dashboard → Bucket service)
# BUCKET_ENDPOINT=https://t3.storageapi.dev
# BUCKET_FORCE_PATH_STYLE=false
# BUCKET_REGION=auto
# BUCKET_MEDIA_NAME=media-qws-mwr1uwvl2hbr93m
# BUCKET_MEDIA_ACCESS_KEY_ID=<from railway bucket credentials>
# BUCKET_MEDIA_SECRET_ACCESS_KEY=<from railway bucket credentials>

# Encryption key for storing sensitive credentials (generate with: openssl rand -hex 32)
# CRITICAL: This key is used to encrypt API keys and secrets in the database
# If changed, all existing credentials will become unrecoverable
INTEGRATION_ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# Note: Rate limiting is handled in-memory (no Redis required).
# Note: Background jobs are handled by pg-boss (uses DATABASE_URL, no external queue service).

# Worker service (Railway): run `bun scripts/worker.ts` as a separate service.
# Required env vars for the worker: DATABASE_URL, RESEND_API_KEY, ANTHROPIC_API_KEY,
# NEXT_PUBLIC_SITE_URL, UNSUBSCRIBE_SECRET, DEFAULT_FROM_EMAIL, NEWSLETTER_FROM_EMAIL,
# OUTREACH_CRON_SECRET (or CRON_SECRET).

# ----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# ----------------------------------------------------------------------------
# Primary NextAuth.js secret (generate with: openssl rand -base64 32)
# Read by lib/auth.ts — takes precedence over NEXTAUTH_SECRET
AUTH_SECRET=your-auth-secret-here

# Legacy NextAuth.js secret name (fallback if AUTH_SECRET is not set)
NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth.js URL (your production domain)
NEXTAUTH_URL=https://yourdomain.com

# ============================================================================
# INTEGRATIONS & API KEYS
# ============================================================================
# API keys and credentials are configured via environment variables for simplicity.
# All credentials are required for production use.

# ----------------------------------------------------------------------------
# Resend (Email Service) - REQUIRED
# ----------------------------------------------------------------------------
# Resend API key for email sending
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here

# Resend webhook secret for signature verification
# CRITICAL: Required for secure webhook handling
# Get from: Resend Dashboard → Webhooks → Your webhook → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Email sender addresses (configure in Resend domain settings)
DEFAULT_FROM_EMAIL=hello@email.yourdomain.com
NEWSLETTER_FROM_EMAIL=newsletter@email.yourdomain.com

# ----------------------------------------------------------------------------
# Outreach System (CRITICAL for N8N Integration)
# ----------------------------------------------------------------------------
# N8N API key for bulk contact imports
# SECURITY: Generate a strong 32+ character random string
# Example generation: openssl rand -base64 32
# This key authenticates N8N workflow requests to /api/outreach/import
# NEVER commit the actual key to git!
OUTREACH_API_KEY=your-random-32-char-string-here

# Cron job secret for scheduled email processing
# SECURITY: Generate a different 32+ character random string
# Example generation: openssl rand -base64 32
# Configure this in Vercel Cron or external scheduler
# Used to authenticate requests to /api/outreach/process
OUTREACH_CRON_SECRET=your-cron-secret-here

# ----------------------------------------------------------------------------
# Newsletter API (Internal)
# ----------------------------------------------------------------------------
# Bearer token protecting internal newsletter endpoints
# (curate, queue stats, job status). Generate with: openssl rand -base64 32
NEWSLETTER_API_KEY=your-newsletter-api-key-here

# Secret used to sign unsubscribe tokens in newsletter and outreach emails
# (lib/newsletter/lib/unsubscribe-token.ts, lib/outreach/lib/utils.ts).
# Generate with: openssl rand -base64 32
UNSUBSCRIBE_SECRET=your-unsubscribe-secret-here

# ----------------------------------------------------------------------------
# OpenAI
# ----------------------------------------------------------------------------
# OpenAI API key — used by:
#   - Newsletter generation (app/api/newsletter/generate/route.ts) for article
#     summarisation and subject-line generation (gpt-4.1-mini).
#   - Outreach reply analyzer (lib/outreach/ai/reply-analyzer.ts) for inbound
#     reply classification + suggested-reply drafting in the LOCKED brand
#     voice (gpt-4.1).
#   - Prospecting call extraction (lib/ai/gg-client.ts → @kenkaiiii/gg-ai).
#     The `process-quo-call` pg-boss job feeds Quo's transcript + summary
#     through gg-ai with provider=openai to extract person name, captured
#     email/phone, follow-up intent, and meeting interest (gpt-4.1-mini).
# Model registry: lib/ai/models.ts — change models in one place.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# ----------------------------------------------------------------------------
# Google (Gemini AI) - Managed via Integrations
# ----------------------------------------------------------------------------
# Configure via Settings → Integrations → Google
# Used for: Chat interfaces, multimodal tasks

# ----------------------------------------------------------------------------
# Perplexity (Research AI) - Managed via Integrations
# ----------------------------------------------------------------------------
# Configure via Settings → Integrations → Perplexity
# Used for: Content research, fact-checking

# ----------------------------------------------------------------------------
# OAuth App Credentials (Managed via Settings UI)
# ----------------------------------------------------------------------------
# OAuth app credentials for integrations (Cal.com, Notion, Slack, etc.) are
# configured through Settings → Integrations in the admin panel. Credentials
# are encrypted with AES-256-GCM (see INTEGRATION_ENCRYPTION_KEY above) and
# stored in the database — no environment variables required.

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# ----------------------------------------------------------------------------
# Site Configuration
# ----------------------------------------------------------------------------
# Public site URL (used for absolute URLs in emails, webhooks, etc.)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ----------------------------------------------------------------------------
# Admin Configuration
# ----------------------------------------------------------------------------
# Default admin email (fallback for UI display when admin user not found)
NEXT_PUBLIC_DEFAULT_ADMIN_EMAIL=admin@yourdomain.com

# ----------------------------------------------------------------------------
# Newsletter Defaults
# ----------------------------------------------------------------------------
# Default sender name for newsletter (used when creating newsletter settings)
NEWSLETTER_DEFAULT_SENDER_NAME=Your Newsletter Name

# Default reply-to email for newsletter (used when creating newsletter settings)
NEWSLETTER_DEFAULT_REPLY_TO=noreply@yourdomain.com

# Brand name shown in generated newsletter emails
NEWSLETTER_BRAND_NAME=Business Insights

# Hex color used for headings/accents in generated newsletter emails
NEWSLETTER_BRAND_COLOR=#0066CC

# Optional footer text appended to generated newsletter emails
NEWSLETTER_FOOTER_TEXT=

# ----------------------------------------------------------------------------
# Cal.com (Booking System)
# ----------------------------------------------------------------------------
# Cal.com webhook secret for booking event verification
# Get from: Cal.com → Webhooks → Your webhook → Secret
CAL_WEBHOOK_SECRET=your-cal-webhook-secret-here

# Test organizer email (used in webhook test scripts only)
TEST_ORGANIZER_EMAIL=organizer@example.com

# ----------------------------------------------------------------------------
# SEO / Verification
# ----------------------------------------------------------------------------
# Google Search Console verification token (rendered in app/layout.tsx metadata)
GOOGLE_SITE_VERIFICATION=your-google-site-verification-token

# ============================================================================
# === Prospecting / Outreach Integrations ===
# ============================================================================
# End-to-end loop: CSV import → CLI-generated SEO/AEO report → Quo call/SMS →
# AI call extraction (gg-ai → Anthropic) → Cap viewer tracking → scheduled
# follow-up notifications. See docs/prospecting.md for the operator guide.
#
# Required on BOTH the `website` and `worker` Railway services (jobs run on
# the worker; webhooks + admin UI run on the website).
#
# `CRON_SECRET` (defined further down under "Cron Jobs") gates the manual
# trigger at /api/cron/poll-cap-analytics. The canonical 5-min schedule is
# self-managed by pg-boss inside the worker — see docs/cap-integration.md.

# ----------------------------------------------------------------------------
# SEO / AEO Report Generation (pg-boss `generate-seo-report` job)
# ----------------------------------------------------------------------------
# Worker-only. CLI template with `{website}`, `{businessName}`, `{prospectId}`,
# `{outDir}` placeholders. The CLI MUST write its output to `<outDir>/<prospectId>.html`.
# Template is split into argv BEFORE substitution — user-controlled values can't
# inject shell metacharacters. See docs/seo-reports.md for the full CLI contract.
SEO_REPORT_CLI_CMD=seo-report --url {website} --out {outDir}/{prospectId}.html

# Output directory the CLI writes report HTML to (the worker reads it back from
# this path before uploading to object storage).
SEO_REPORT_OUT_DIR=./reports

# Per-prospect timeout in milliseconds. Process is SIGTERM'd on expiry.
SEO_REPORT_TIMEOUT_MS=300000

# Local-only worker concurrency for this queue (number of in-flight prospects
# per worker node). Tune to match CLI CPU/IO cost.
SEO_REPORT_WORKER_CONCURRENCY=2

# ----------------------------------------------------------------------------
# Quo (formerly OpenPhone — SMS + Calls)
# ----------------------------------------------------------------------------
# Quo REST API key. Sent verbatim in the `Authorization` header (NO Bearer prefix).
# Generate from: Quo workspace → Settings → API → Generate API key
# Used by lib/quo/client.ts for sending SMS, fetching call metadata/summary/transcript,
# and creating contacts.
QUO_API_KEY=

# Webhook signing secret for verifying inbound Quo webhook payloads
# (message.received, call.completed, call.summary.completed, call.transcript.completed).
# Get from: Quo workspace → Settings → Webhooks → Your webhook → Signing secret
QUO_WEBHOOK_SECRET=

# Your Quo phone number in E.164 format (e.g. +15551234567) — used as the
# default `from` when sending SMS through sendSms() in lib/quo/client.ts.
QUO_PHONE_NUMBER=

# Optional: override the Quo API base URL (defaults to https://api.openphone.com/v1).
# Useful for pointing tests / staging at a mock server.
# QUO_API_BASE=https://api.openphone.com/v1

# ----------------------------------------------------------------------------
# Cap (cap.so — open-source Loom alternative)
# ----------------------------------------------------------------------------
# Cap developer SECRET key. Sent as `Authorization: Bearer <key>` to Cap's
# REST API at https://cap.so/api/developer/v1. Generate at
# https://cap.so/dashboard/developers (Create App → copy the `csk_...` key).
# Used by lib/cap/client.ts. See lib/cap/README.md for scope limitations
# (only returns videos created via the Cap developer SDK, not desktop/web).
CAP_API_KEY=

# Optional: override the Cap REST API base URL. Defaults to https://cap.so/api.
# Set if you self-host Cap on a custom domain.
# CAP_API_BASE=https://cap.so/api

# Optional: custom domain used for Cap share links (e.g. video.acme.com).
# When set, getVideo() in lib/cap/client.ts builds share URLs against this
# host instead of cap.so. Leave unset to use the default cap.so/s/<id> form.
# CAP_CUSTOM_DOMAIN=

# Lookback window (days) for the `poll-cap-analytics` pg-boss job in
# scripts/worker.ts. Only polls prospects with `lastTouchedAt` newer than this
# OR an active outreach stage (emailed / email_captured / phone_captured).
# Bigger window = more Cap API calls per tick. Defaults to 30 if unset.
CAP_POLL_LOOKBACK_DAYS=30

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Minimum log level for the newsletter logger (debug | info | warn | error)
# Read by lib/newsletter/lib/logger.ts; defaults to "info" if unset
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Development / Testing
# ----------------------------------------------------------------------------
# Enable webhook signature debugging (DO NOT enable in production)
# Logs signature verification details for troubleshooting webhook issues
DEBUG_WEBHOOK_SIGNATURE=false

# ----------------------------------------------------------------------------
# Cron Jobs (Background Processing)
# ----------------------------------------------------------------------------
# Secret token for authenticating cron job requests (generate with: openssl rand -base64 32)
# Used to protect cron endpoints from unauthorized access
CRON_SECRET=your-cron-secret-here

# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# BEST PRACTICES:
# - Never commit actual credentials to version control
# - Use different keys for development, staging, and production
# - Rotate API keys every 90 days
# - Store production secrets in Vercel Environment Variables
